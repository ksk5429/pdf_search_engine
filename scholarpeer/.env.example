# ── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
POLITE_EMAIL=you@example.com

# ── Corpus paths (Windows examples) ───────────────────────────────────────
SP_CORPUS_DIR=F:/TREE_OF_THOUGHT/PHD/papers/literature_review
SP_PDF_DIR=F:/TREE_OF_THOUGHT/PHD/papers/new_pdf

# ── Services ──────────────────────────────────────────────────────────────
SP_QDRANT_URL=http://localhost:6333
SP_GROBID_URL=http://localhost:8070

# ── Models ────────────────────────────────────────────────────────────────
SP_DENSE_MODEL=BAAI/bge-m3
SP_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SP_COLPALI_MODEL=vidore/colqwen2.5-v0.2
SP_DEVICE=cuda

# ── Agents ────────────────────────────────────────────────────────────────
SP_LEADER_MODEL=claude-opus-4-7
SP_SPECIALIST_MODEL=claude-sonnet-4-6
SP_FORMATTER_MODEL=claude-haiku-4-5

# ── Retrieval tuning ──────────────────────────────────────────────────────
SP_TOP_K_DENSE=30
SP_TOP_K_SPARSE=30
SP_TOP_K_RERANK=10
SP_CHUNK_TOKENS=512
SP_CHUNK_OVERLAP=64

# ── Logging ───────────────────────────────────────────────────────────────
SP_LOG_LEVEL=INFO
SP_LOG_FORMAT=console   # console | json
